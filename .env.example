# Shared multi-model inference endpoint (OpenAI-compatible).
INFERENCE_API_KEY=
INFERENCE_BASE_URL=https://model.service-inference.ai/v1

# Optional second provider — set to enable OpenRouter routing across providers.
OPENROUTER_API_KEY=
# OpenRouter model catalog (defaults to ./openrouter-models.json when the key is set).
# ROUTER_OPENROUTER_MODELS=./openrouter-models.json

# Optional: path to a JSON file of real per-model prices to override the estimates:
#   {"gpt-5.4": {"price_in": 5.0, "price_out": 15.0}, ...}
# ROUTER_PRICING_JSON=./pricing.json

# --- Monetization (any operator can charge clients a markup over routed cost) ---
ROUTER_BUDGET_CAP=50          # global hard spend cap (USD)
ROUTER_MARKUP_PCT=0.20        # bill clients +20% over upstream model cost
ROUTER_FLAT_FEE=0             # optional flat fee per call (USD)
ROUTER_MIN_CHARGE=0           # optional minimum charge per call (USD)
# Per-client API keys for metering/billing: "key1:clientA,key2:clientB"
# Clients send their key as the X-API-Key header.
ROUTER_CLIENT_KEYS=
