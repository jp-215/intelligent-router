# Shared multi-model inference endpoint (OpenAI-compatible).
INFERENCE_API_KEY=
INFERENCE_BASE_URL=https://model.service-inference.ai/v1

# Optional second provider — set to enable OpenRouter routing.
OPENROUTER_API_KEY=

# Optional: path to a JSON file of real per-model prices to override the estimates:
#   {"gpt-5.4": {"price_in": 5.0, "price_out": 15.0}, ...}
# ROUTER_PRICING_JSON=./pricing.json
